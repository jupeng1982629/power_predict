# Database
POSTGRES_IMAGE=docker.m.daocloud.io/library/postgres:16-alpine
POSTGRES_DB=power_predict
POSTGRES_USER=power_predict
POSTGRES_PASSWORD=power_predict
POSTGRES_PORT=5432

# Cache
REDIS_IMAGE=docker.m.daocloud.io/library/redis:7-alpine
REDIS_PORT=6379

# Object Storage
MINIO_IMAGE=docker.m.daocloud.io/minio/minio:RELEASE.2025-02-03T21-03-04Z
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Streaming
KAFKA_IMAGE=docker.m.daocloud.io/apache/kafka:3.8.0
KAFKA_PORT=9092
KAFKA_KRAFT_CLUSTER_ID=abcdefghijklmnopqrstuv

# MLflow
MLFLOW_IMAGE=ghcr.m.daocloud.io/mlflow/mlflow:v2.15.1
MLFLOW_PORT=15000

# Identity (Stage 4)
KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:26.0.7
KEYCLOAK_PORT=18081
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin123!

# Optional compute UIs
SPARK_UI_PORT=8081
FLINK_UI_PORT=8082

# Optional app ports
GATEWAY_IMAGE=gateway-service:local
PLANT_IMAGE=plant-service:local
MONITOR_IMAGE=monitor-service:local
FORECAST_IMAGE=forecast-service:local
SYSTEM_IMAGE=system-service:local
FEATURE_IMAGE=feature-service:local
MODEL_IMAGE=model-service:local
INFERENCE_IMAGE=inference-service:local
WEB_IMAGE=web-portal:local
GATEWAY_PORT=8080
WEB_PORT=5173
